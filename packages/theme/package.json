{
  "name": "@kairo-ui/theme",
  "version": "0.0.0",
  "description": "CSS design tokens and themes for Kairo.",
  "type": "module",
  "license": "MIT",
  "author": "Kairo Contributors",
  "homepage": "https://github.com/qiukelab/Kairo-UI#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiukelab/Kairo-UI.git",
    "directory": "packages/theme"
  },
  "bugs": {
    "url": "https://github.com/qiukelab/Kairo-UI/issues"
  },
  "keywords": [
    "css",
    "design-tokens",
    "design-system",
    "theme",
    "theming",
    "css-variables",
    "dark-mode",
    "ui"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./css/*": "./css/*"
  },
  "scripts": {
    "build": "tsdown && node scripts/build-css.mjs",
    "dev": "tsdown --watch",
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@kairo-ui/tsconfig": "workspace:*",
    "lightningcss": "^1.32.0",
    "tsdown": "0.22.9",
    "typescript": "5.9.3",
    "unrun": "0.3.1",
    "vitest": "4.1.10"
  }
}
