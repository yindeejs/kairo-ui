    "check-exports": "turbo run check-exports",
    "format": "prettier --write .",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/cli": "2.31.1",
    "@eslint/js": "9.39.5",
