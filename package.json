{
  "name": "kairo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "author": "Kairo Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yindeejs/kairo-ui.git"
  },
  "bugs": {
    "url": "https://github.com/yindeejs/kairo-ui/issues"
  },
  "homepage": "https://github.com/yindeejs/kairo-ui#readme",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint",
    "check-exports": "turbo run check-exports",
    "format": "oxfmt",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/cli": "2.31.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "publint": "0.3.21",
    "turbo": "2.10.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
