{
  "name": "kairo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "author": "Kairo Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiukelab/Kairo-UI.git"
  },
  "bugs": {
    "url": "https://github.com/qiukelab/Kairo-UI/issues"
  },
  "homepage": "https://github.com/qiukelab/Kairo-UI#readme",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
